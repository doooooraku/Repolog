# Repolog Environment Variables Template
# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real values.

# ── AdMob ────────────────────────────────────────────
# App IDs: injected into native manifests at build time.
# Leave blank to use Google's test App IDs during development.
ADMOB_ANDROID_APP_ID=
ADMOB_IOS_APP_ID=

# Banner Unit IDs: used at runtime by adService.ts.
# Leave blank to use TestIds.ADAPTIVE_BANNER in __DEV__.
ADMOB_ANDROID_BANNER_ID=
ADMOB_IOS_BANNER_ID=

# UMP consent debugging (optional).
# Set to EEA to force EU consent flow on test devices.
ADMOB_CONSENT_DEBUG_GEOGRAPHY=
ADMOB_CONSENT_TEST_DEVICE_IDS=

# iOS ATT tracking description (optional override).
# Default: "This identifier will be used to deliver relevant ads to Free plan users."
# ADMOB_USER_TRACKING_USAGE_DESCRIPTION=

# Set to "1" to skip delayAppMeasurementInit (not recommended).
# ADMOB_DISABLE_DELAY_APP_MEASUREMENT_INIT=

# ── RevenueCat ───────────────────────────────────────
REVENUECAT_ANDROID_API_KEY=
REVENUECAT_IOS_API_KEY=

# Set to "1" to enable RevenueCat debug logs.
IAP_DEBUG=0

# ── Screenshot Mode ─────────────────────────────────
# Set to "1" to hide ads for clean store listing screenshots.
SCREENSHOT_MODE=0
